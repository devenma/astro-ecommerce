---
import Layout from "@layouts/Layout.astro";
import Header from "@components/astro/Header.astro";
import Footer from "@components/astro/Footer.astro";
import "../styles/global.css";
import { Image } from "astro:assets";
const productsData = [
  {
    id: 1,
    name: "Campera Importada Gabardina",
    brand: "Kisiron By Hesed",
    price: 33500,
    colors: ["#000000", "#f5f5dc", "#3b82f6"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC_wB3uTr1OD1kb8nH88mkqtzWkoX5PuBVwRlCHavPvcOHjZ_5Iu0IXgZCtR-894D8YPQB-r_GXC7wL4n-Djlvjj0-AKIfQtOmJYBN_Ui625noqM0DxUf17hCnnjYolNOP4qaAKXUHBzJX4jZ2GU-VT6ndC8kZilvmdbT69Z4px1d23s8IHNYI80QXebSTwDqsKSKU5HcrKzS36d-CyItcsanXezdPQLA3kAED0bIGcrDXQpEBWyKnv8jlBuMaKAaeesPu3lLBVMHw",
  },
  {
    id: 2,
    name: "Chomba De Bremer Grueso Liso",
    brand: "Kisiron By Hesed",
    price: 23000,
    colors: ["#000000", "#9ca3af"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuD_mPVcdJKBS9ZaP7n3oQBi90YIgSnGrK3p8t5FJcl4Nh-mRX3A3r3C3FiBHHPAufmt1PW42Je8IMQemMIvYoFyB2NrKrJTeS1yh0NLc6Yl1-tmBM2fzuE871M9SOEKTNb6ANV7JymiBWD8DPahhCf6F9TZx461X7dMm791xC9vrkw_kJTGoxrhokF81QJBhfvhGxbcBbZGscaKM3WdvAJi2vTGxl2X_ygHQ6UjXeERMTY1tPUkn9k7ufVAv-SlVp8jmVZcUx1y0wY",
  },
  {
    id: 3,
    name: "Sweater Importado De Bremer",
    brand: "Kisiron By Hesed",
    price: 22500,
    colors: ["#dc2626", "#000000"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuCSrI8MIu5eXX7ToL0yM3WD938aamKBmVnRU7TcMGmwkXpTsKhfiJdLw_47qGpR-rsIZUe5y2e8L1M9UsBFZbpUqs3q7jkkY1taLutNatyxVVBLJgpZdbVBiJLEZJ0Y8-lnjjuADgBdcVEeZjfqp9ctKyFud0kRW9644O1JilEDLZpmRZtKMRXEFqhjsybRUcYWQsPvKcEUFJQjmBrZLYxJAu3OuW6aUt4QwRErEfj2J5-oZtVT5Me5UF3ebbAL63tphc6omXSls-g",
  },
  {
    id: 4,
    name: "Remera Nicoletta",
    brand: "Kisiron By Hesed",
    price: 15000,
    colors: ["#000000", "#f5f5dc"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuCBTxwO8eexr_6IjmeSwXN5auDJpfKbSnebnmfirNmTYLzal5ndzIuWMkTFTn0F-x7gHOwVMAEemRgVhbxlM7To1H_9SOpwZtDTk_axj2A0OrQi45QO0TG1rfttrlZ3wFW0KdrD4o_RYtC4G2cDjkXts-QcxpWNjIExRnwcELjt1qGBDiVihOR9FM_WchxEKUA9XMCcSiIEUuMTNaVIKWQhIcyHiOe__pV1LqZ310Oc-5F2C-AjyzhhSogx_ywfhzMnB6jwIkh4koY",
  },
];
---

<Layout>
  <body>
    <!-- BEGIN: TopHeader -->
    <Header />
    <!-- END: TopHeader -->
    <main class="bg-slate-100">
      <!-- BEGIN: HeroSection -->
      <section class="relative bg-[#d3d9ce] lg:h-150 overflow-hidden">
        <!-- Background Text Elements (from reference image) -->
        <div
          class="absolute inset-0 flex flex-col justify-center select-none pointer-events-none px-8 opacity-20"
        >
          <span class="text-[120px] font-bold leading-tight uppercase"
            >Nueva</span
          >
          <span class="text-[120px] font-bold leading-tight uppercase"
            >Temporada</span
          >
        </div>
        <div
          class="container mx-auto h-full px-4 flex flex-col lg:flex-row items-center justify-center relative"
        >
          <!-- Hero Image (Woman in sweater) -->
          <div class="md:p-16 h-full flex items-end justify-center pt-10">
            <img
              alt="Fashion Hero"
              class="h-[90%] object-contain drop-shadow-2xl"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCyOaBRDL29RRM1qwyf1sER9gbdt0HxmvSXSXO6K4o48dNr1HRPCYa-Miw5NeZ8elKXpVm4E_v9T0pOT5xDCog-GVjhtgY3hWwPgsOLN6nQAQ9DhnzT27F4JDO8W1d9_6EtltzVyBgiubHvMoP5LTMDlOEqeFje5wOQ1k6hKWosLecZlULk1oUlfGplUfrNOaN8tHoDT_itEDiQ-Zjq9V0EOlxMyedJ5MxfQWFD_O2orV13AJPbwTFigA7vih4RdK3GkxR2wU23Iws"
            />
          </div>
          <!-- Hero Content -->
          <div class="lg:w-1/2 text-center lg:text-left z-10 py-8 lg:py-0">
            <h2
              class="text-4xl lg:text-8xl font-black italic text-black leading-none mb-2"
            >
              FW'26
            </h2>
            <h3
              class="text-3xl lg:text-5xl font-bold uppercase tracking-widest text-black mb-8"
            >
              OTOÑO/INVIERNO
            </h3>
            <div
              class="flex flex-col md:flex-row items-center gap-4 lg:justify-start"
            >
              <a
                class="bg-white text-black px-10 py-4 rounded-full font-bold text-lg shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all flex items-center gap-2"
                href="#"
              >
                Ver ingresos
              </a>
            </div>
          </div>
          <!-- Carousel Indicators -->
          <div
            class="absolute bottom-2 md:bottom-8 left-1/2 -translate-x-1/2 flex space-x-2"
          >
            <div class="w-2.5 h-2.5 rounded-full bg-black"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-gray-400"></div>
          </div>
        </div>
        <!-- Arrow Navigation -->
        <button
          class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/50 p-2 rounded-full hover:bg-white transition-all hidden md:block"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M15 19l-7-7 7-7"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"></path>
          </svg>
        </button>
        <button
          class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/50 p-2 rounded-full hover:bg-white transition-all hidden md:block"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M9 5l7 7-7 7"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"></path>
          </svg>
        </button>
      </section>
      <!-- END: HeroSection -->
      <!-- BEGIN: PromoBanners -->
      <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4">
          <h4 class="text-xl font-bold mb-6 text-gray-800">Novedades</h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Banner 1: Rebajados -->
            <div
              class="bg-[#fdf3f3] p-6 rounded-lg border border-pink-100 flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
            >
              <h5 class="text-3xl font-serif text-[#1e3a5f] font-bold">
                Findes
              </h5>
              <p class="uppercase tracking-widest font-bold text-[#1e3a5f]">
                REBAJADOS
              </p>
              <p class="mt-4 text-primary font-medium">
                Montos Mínimos Rebajados
              </p>
            </div>
            <!-- Banner 2: FW26 -->
            <div
              class="bg-[#e2e8df] p-6 rounded-lg flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
            >
              <h5 class="text-5xl font-black italic mb-2">FW'26</h5>
              <p class="uppercase font-bold tracking-tight">OTOÑO/INVIERNO</p>
            </div>
            <!-- Banner 3: Precios Bajos -->
            <div
              class="relative overflow-hidden bg-white p-6 rounded-lg border-2 border-primary/20 flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
            >
              <div class="absolute inset-0 bg-blue-50/30 z-0"></div>
              <p class="relative z-10 text-gray-700 font-medium">
                Aprovechá los precios más baratos <span class="font-bold"
                  >solo disponibles en</span
                >
              </p>
              <span class="relative z-10 text-xl font-bold text-primary"
                >distrito<span class="text-black">moda</span></span
              >
              <div
                class="mt-4 bg-primary text-white text-[10px] px-2 py-1 rounded uppercase font-bold relative z-10"
              >
                precio exclusivo dm
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- END: PromoBanners -->
      <!-- BEGIN: ProductGrid -->
      <section class="py-12">
        <div class="container mx-auto px-4">
          <div class="flex items-center justify-between mb-8">
            <h4 class="text-xl font-bold text-gray-800">Tiendas destacadas</h4>
            <a
              class="text-primary font-semibold flex items-center hover:underline"
              href="#"
            >
              Ver más
              <svg
                class="h-4 w-4 ml-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M9 5l7 7-7 7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"></path>
              </svg>
            </a>
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-8">
            {
              productsData.map((product) => (
                <div
                  data-id={product.id}
                  class="bg-white rounded-lg shadow-sm overflow-hidden group cursor-pointer hover:shadow-md transition-shadow"
                >
                  <div class="overflow-hidden">
                    <img
                      src={product.image}
                      alt={product.name}
                      class="object-cover group-hover:scale-105 transition-transform"
                    />
                  </div>
                  <div class="p-4">
                    <h5 class="text-sm text-gray-500">{product.brand}</h5>
                    <h4 class="text-lg font-semibold text-gray-800">
                      {product.name}
                    </h4>
                    <p class="text-primary font-bold mt-2">${product.price}</p>
                  </div>
                  <div class="flex items-center space-x-1 px-4 pb-4">
                    {product.colors.map((color) => (
                      <span
                        class="w-4 h-4 rounded-full border border-gray-300"
                        style={{ backgroundColor: color }}
                      />
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>
      <!-- END: ProductGrid -->
    </main>
    <Footer />
  </body>
</Layout>
