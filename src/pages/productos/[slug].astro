          </details>
          <details class="group py-4">
            <summary
              class="flex justify-between items-center cursor-pointer list-none font-bold text-sm uppercase tracking-wider"
            >
              Shipping &amp; Returns
              <span
                class="material-symbols-outlined transition-transform group-open:rotate-180"
                >expand_more</span
              >
            </summary>
            <div class="pt-4 text-sm text-on-surface-variant leading-relaxed">
              Free standard shipping on orders over $150. Easy 30-day returns.
            </div>
          </details>
        </section>
      </div>
    </div>
    <!-- Related Products Section -->
