---
import { getProductBySlug } from "@lib/products";
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { formatPrice } from "@lib/utils";
import { getProductsByStoreSlug } from "@lib/products";
import ProductsGrid from "@/components/astro/ProductsGrid.astro";
import {
  ChevronRight,
  ChevronUp,
  HeartPlus,
  Star,
  ArrowRightToLine,
  BadgeCheck,
  ShoppingCart,
} from "@lucide/astro";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/productos");
}

const productData = await getProductBySlug(slug);
if (!productData) {
  return Astro.redirect("/productos");
}

const brand_slug = productData.brand?.slug;
const brand_link = brand_slug && `/tiendas/${brand_slug}`;

const relatedProducts = brand_slug
  ? await getProductsByStoreSlug(brand_slug)
  : [];
---

<Layout>
  <div class="container max-w-7xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav
      class="flex items-center gap-2 mb-8 text-xs font-label uppercase tracking-widest text-on-surface-variant/70"
    >
      <a class="hover:text-primary" href="#">Home</a>
      <span class="material-symbols-outlined text-[14px]"><ChevronRight /></span
      >
      <a class="hover:text-primary" href="#">Women</a>
      <span class="material-symbols-outlined text-[14px]"><ChevronRight /></span
      >
      <span class="text-on-surface font-semibold">Dresses</span>
    </nav>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Product Media: Asymmetric Layout -->
      <div class="lg:col-span-7 flex flex-col md:flex-row gap-6">
        <!-- Thumbnail Strip -->
        <div class="flex md:flex-col gap-4 order-2 md:order-1">
          {
            productData.images?.map((image, index) => (
              <button
                class={`w-20 h-28 rounded-lg overflow-hidden border-2 ${
                  index === 0
                    ? "border-primary ring-2 ring-primary/10"
                    : "border-outline-variant/30 hover:border-primary"
                } transition-colors`}
              >
                <Image
                  width="20"
                  height="28"
                  loading="eager"
                  class="w-full h-full object-cover"
                  alt={`${productData.title}`}
                  src={image}
                />
              </button>
            ))
          }
        </div>
        <!-- Hero Image -->
        <div
          class="flex-1 order-1 md:order-2 relative group overflow-hidden rounded-xl"
        >
          <Image
            width="400"
            height="600"
            loading="eager"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            alt={productData.title}
            src={productData.images?.[0] ??
              "/assets/images/product-placeholder.png"}
          />
          <button
            class="absolute top-6 hover:cursor-pointer bg-white right-6 glass-card p-3 rounded-full text-primary hover:bg-primary hover:text-on-primary transition-all shadow-lg group-hover:scale-110"
          >
            <span class="material-symbols-outlined"><HeartPlus /></span>
          </button>
        </div>
      </div>
      <!-- Product Details -->
      <div class="lg:col-span-5 space-y-10">
        <section class="space-y-4">
          <div class="flex items-center justify-between">
            <a href={brand_link ?? "#"} class="text-sm text-primary font-medium"
              >{productData.brand?.name}</a
            >
            <div class="flex items-center gap-1 text-tertiary">
              <span
                class="material-symbols-outlined text-sm"
                style="font-variation-settings: 'FILL' 1;"><Star /></span
              >
              <span class="text-sm font-semibold">4.8</span>
              <span class="text-on-surface-variant text-xs">(124 reviews)</span>
            </div>
          </div>
          <h1
            class="text-4xl md:text-5xl font-headline font-bold text-on-surface tracking-tight"
          >
            {productData.title}
          </h1>
          <div class="flex items-baseline gap-4">
            <span class="text-3xl font-bold text-on-surface"
              >{
                formatPrice(
                  productData.price ?? 0,
                  productData.currency ?? "ARS",
                )
              }</span
            >
            <span class="text-lg text-on-surface-variant/50 line-through"
            ></span>
          </div>
          <!-- <p class="text-on-surface-variant leading-relaxed body-lg">
            A lightweight and breathable summer dress made from sustainable
            cotton. Features a flattering V-neckline and a midi-length
            silhouette, designed for effortless elegance from sunrise to sunset.
          </p> -->
        </section>
        <!-- Size Selector -->
        <section class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-sm font-bold uppercase tracking-wider">Talle</span
            >
            <button
              class="text-xs text-primary underline cursor-pointer font-medium"
              >Guia de talles</button
            >
          </div>
          <div class="flex flex-wrap gap-3">
            {
              productData.sizes?.map((size) => (
                <button class="w-12 h-12 cursor-pointer flex items-center justify-center rounded-lg border border-outline-variant/30 hover:border-primary hover:text-primary text-sm font-medium transition-colors">
                  {size}
                </button>
              ))
            }
          </div>
        </section>
        <!-- Actions -->
        <section class="flex flex-col gap-4">
          <button
            class="w-full py-5 cursor-pointer rounded-xl bg-primary-accent hover:bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all flex items-center justify-center gap-3"
          >
            <span class="material-symbols-outlined"><ShoppingCart /></span>
            Añadir al carrito
          </button>
          <div
            class="flex items-center justify-center gap-2 py-3 bg-surface-container-low rounded-xl"
          >
            <span
              class="material-symbols-outlined text-tertiary"
              style="font-variation-settings: 'FILL' 1;"><BadgeCheck /></span
            >
            {
              productData.brand?.name && (
                <span class="text-xs font-medium text-on-surface-variant">
                  {productData.brand.name} (Tienda verificada)
                </span>
              )
            }
          </div>
        </section>
        <!-- Accordions -->
        <section
          class="divide-y divide-outline-variant/10 border-t border-b border-outline-variant/10"
        >
          <details class="group py-4" open="">
            <summary
              class="flex justify-between items-center cursor-pointer list-none font-bold text-sm uppercase tracking-wider"
            >
              Fabric &amp; Care
              <span
                class="material-symbols-outlined transition-transform group-open:rotate-180"
                ><ChevronUp /></span
              >
            </summary>
            <div class="pt-4 text-sm text-on-surface-variant leading-relaxed">
              <ul class="list-disc pl-4 space-y-2">
                <li>100% Organic Sustainable Cotton</li>
                <li>Hand wash cold, line dry in shade</li>
                <li>Cool iron if needed</li>
                <li>Eco-friendly dyes used</li>
              </ul>
            </div>
          </details>
          <details class="group py-4">
            <summary
              class="flex justify-between items-center cursor-pointer list-none font-bold text-sm uppercase tracking-wider"
            >
              Shipping &amp; Returns
              <span
                class="material-symbols-outlined transition-transform group-open:rotate-180"
                ><ChevronUp /></span
              >
            </summary>
            <div class="pt-4 text-sm text-on-surface-variant leading-relaxed">
              Free standard shipping on orders over $150. Easy 30-day returns.
            </div>
          </details>
        </section>
      </div>
    </div>
    <ProductsGrid
      title="Más de la misma tienda"
      link={brand_link && brand_link}
      productsData={relatedProducts}
    />
  </div>
</Layout>
