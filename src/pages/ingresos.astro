---
import Layout from "@layouts/Layout.astro";
---

<Layout>
  <div class="container max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-6">Ingresos</h1>
    <p class="text-lg text-gray-600">
      Aquí podrás ver los ingresos generados por tus ventas, con gráficos y
      estadísticas detalladas para ayudarte a entender el rendimiento de tu
      tienda.
    </p>
  </div>
</Layout>
