---
import { Search } from "@lucide/astro";
---

<!-- Search Bar -->
<div class="max-w-2xl">
  <form class="group">
    <div
      class="flex items-center has-[input:focus]:outline-2 outline-secondary justify-center input-wrapper border border-slate-200 rounded-lg"
    >
      <input
        class="w-full px-4 py-2 rounded-l-lg focus:outline-none"
        placeholder="Buscar producto o tienda..."
        type="text"
      />
      <button
        class="cursor-pointer rounded-r-lg h-full px-2 border-l border-slate-200 text-gray-500 hover:text-gray-700 focus:outline-none"
        type="submit"
      >
        <Search class="size-5.5" />
      </button>
    </div>
  </form>
</div>
