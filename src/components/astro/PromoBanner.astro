---
import Logo from "@components/astro/ui/Logo.astro";
---

<section data-component="PromoBanner" class="py-12 bg-gray-50">
  <div class="container max-w-7xl mx-auto px-4">
    <h4 class="text-xl font-bold mb-6 text-gray-800">Novedades</h4>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div
        class="bg-[#fdf3f3] p-6 rounded-lg border border-pink-100 flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
      >
        <h5 class="text-3xl font-serif text-[#1e3a5f] font-bold">Findes</h5>
        <p class="uppercase tracking-widest font-bold text-[#1e3a5f]">
          REBAJADOS
        </p>
        <p class="mt-4 text-primary font-medium">Montos Mínimos Rebajados</p>
      </div>

      <div
        class="bg-[#e2e8df] p-6 rounded-lg flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
      >
        <h5 class="text-5xl font-black italic mb-2">FW'26</h5>
        <p class="uppercase font-bold tracking-tight">OTOÑO/INVIERNO</p>
      </div>

      <div
        class="relative overflow-hidden bg-white p-6 rounded-lg border-2 border-primary/20 flex flex-col items-center justify-center text-center group cursor-pointer hover:shadow-md transition-shadow"
      >
        <div class="absolute inset-0 bg-blue-50/30 z-0"></div>
        <p class="relative z-10 text-gray-700 font-medium">
          Aprovechá los precios más baratos <span class="font-bold"
            >solo disponibles en</span
          >
        </p>
        <Logo
          size="small"
          className="mt-2 relative z-10"
          textClass="text-sm relative z-10"
        />
        <div
          class="mt-4 bg-primary text-white text-[10px] px-2 py-1 rounded uppercase font-bold relative z-10"
        >
          precio exclusivo dm
        </div>
      </div>
    </div>
  </div>
</section>
