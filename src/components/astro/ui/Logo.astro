---
import { Image } from "astro:assets";

type Props = {
  size?: "small" | "medium" | "large";
  text?: string;
  className?: string;
  textClass?: string;
  loading?: "eager" | "lazy";
};

const {
  size = "small",
  text = "",
  className = "",
  textClass = "",
  loading = "eager",
}: Props = Astro.props;
const heights = { small: 30, medium: 40, large: 60 };
---

<a
  data-component-ui="Logo"
  href="/"
  aria-label="home link"
  class:list={[className, "dm-logo flex items-center justify-center"]}
>
  <Image
    src="/logo.svg"
    height={heights[size]}
    width={heights[size] * 3.75}
    alt="page logo"
    loading={loading}
  />
  {
    text && (
      <span
        class:list={[
          textClass,
          "ml-2 pl-2 border-l border-secondary text-pretty max-w-32 tracking-tighter leading-tight font-semibold text-secondary uppercase text-sm",
        ]}
      >
        {text}
      </span>
    )
  }
</a>
