---
const { text = "", variant = "primary", className = "" } = Astro.props;

const baseClasses =
  "cursor-pointer px-3 py-2.5 tracking-tight rounded-md hover:shadow-md text-xs font-bold transition-all uppercase";

const variantClasses = {
  primary: "text-white bg-primary border border-primary",
  secondary:
    "border border-primary text-red-600 hover:bg-primary hover:text-white",
};
---

<button class:list={[className, baseClasses, variantClasses[variant]]}
  >{text}</button
>
