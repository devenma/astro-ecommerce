# === Drupal Backend ===
DRUPAL_BASE_URL=https://api.tu-ecommerce.com
DRUPAL_API_TOKEN=                    # Bearer token para endpoints protegidos

# === Modo Desarrollo ===
USE_MOCK_DATA=true                   # true = usa JSON locales, false = llama a Drupal real

# === Deploy ===
PUBLIC_SITE_URL=https://tu-ecommerce.com