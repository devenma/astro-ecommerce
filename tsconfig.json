{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "types": [
      "./worker-configuration.d.ts",
      "node"
    ],
    "baseUrl": ".",
    "strictNullChecks": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@content/*": [
        "./src/content/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@types-local/*": [
        "./src/types/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "./worker-configuration.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ]
}